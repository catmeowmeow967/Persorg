<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox fx:id="columnContainer" xmlns="http://javafx.com/javafx/17.0.2"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.ColumnController"
      spacing="0"
      prefWidth="272"
      minWidth="272"
      maxWidth="272"
      style="-fx-background-color: white; -fx-border-color: black; -fx-border-width: 1;">
    <HBox spacing="8" alignment="CENTER_LEFT"
          style="-fx-padding: 10 10 4 10; -fx-border-color: black; -fx-border-width: 0 0 1 0;">
        <TextField fx:id="columnTitleField"
                   style="-fx-background-color: transparent;
                         -fx-border-color: transparent;
                         -fx-font-weight: bold;
                         -fx-font-size: 14;
                         -fx-text-fill: black;
                         -fx-padding: 2 0;
                         -fx-pref-width: 180;"
                   onAction="#handleTitleUpdate"/>
        <HBox HBox.hgrow="ALWAYS" alignment="CENTER_RIGHT">
            <Label fx:id="taskCountLabel" text="0"
                   style="-fx-text-fill: #333;
                          -fx-font-size: 12;
                          -fx-padding: 2 8;
                          -fx-background-color: #e0e0e0;"/>
        </HBox>
        <Button text="..." prefWidth="24" prefHeight="24"
                style="-fx-background-color: transparent;
                       -fx-text-fill: black;
                       -fx-font-size: 12;
                       -fx-cursor: hand;
                       -fx-padding: 0;"
                onMouseEntered="#handleButtonHover"
                onMouseExited="#handleButtonExit"
                onAction="#handleMenu"/>
    </HBox>
    <ScrollPane vbarPolicy="AS_NEEDED" hbarPolicy="NEVER"
                fitToWidth="true"
                style="-fx-background-color: transparent;
                      -fx-background: transparent;
                      -fx-padding: 0 10 10 10;
                      -fx-border-color: transparent;">
        <VBox fx:id="tasksContainer" spacing="8" style="-fx-padding: 0;"/>
    </ScrollPane>
    <HBox style="-fx-padding: 0 10 10 10;" alignment="CENTER_LEFT" spacing="8">
        <Button fx:id="addTaskButton" text="+ Задача"
                prefWidth="156" prefHeight="32"
                style="-fx-background-color: #1565c0;
                       -fx-text-fill: white;
                       -fx-border-color: transparent;
                       -fx-font-size: 12;
                       -fx-cursor: hand;
                       -fx-alignment: center-left;
                       -fx-background-radius: 0;"
                onMouseEntered="#handleButtonHover"
                onMouseExited="#handleButtonExit"
                onAction="#handleAddTask"/>
        <Button text="+" prefWidth="32" prefHeight="32"
                style="-fx-background-color: #e0e0e0;
                       -fx-background-radius: 0;
                       -fx-text-fill: black;
                       -fx-font-size: 14;
                       -fx-font-weight: bold;
                       -fx-cursor: hand;"
                onMouseEntered="#handleButtonHover"
                onMouseExited="#handleButtonExit"
                onAction="#handleTemplateTask"/>
    </HBox>
</VBox>