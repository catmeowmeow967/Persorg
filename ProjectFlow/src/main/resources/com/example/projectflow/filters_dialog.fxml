<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane prefHeight="600" prefWidth="650"
            style="-fx-background-color: white; -fx-border-color: black; -fx-border-width: 1;"
            xmlns="http://javafx.com/javafx/17.0.2"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.FiltersController">
    <top>
        <Label text="ФИЛЬТРЫ"
               style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: white; -fx-background-color: #1565c0; -fx-padding: 16;"
               maxWidth="Infinity"/>
    </top>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: white;">
            <VBox spacing="20" style="-fx-padding: 20;">
                <VBox spacing="10">
                    <Label text="ПОИСК" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                    <TextField fx:id="searchField"
                               promptText="Введите текст..."
                               style="-fx-font-size: 13; -fx-border-color: #999; -fx-border-width: 1;"/>
                </VBox>
                <VBox spacing="10">
                    <Label text="ПРИОРИТЕТ" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                    <FlowPane hgap="15" vgap="10">
                        <CheckBox fx:id="priorityLow" text="Низкий"/>
                        <CheckBox fx:id="priorityMedium" text="Средний"/>
                        <CheckBox fx:id="priorityHigh" text="Высокий"/>
                        <CheckBox fx:id="priorityCritical" text="Критический"/>
                    </FlowPane>
                </VBox>
                <VBox spacing="10">
                    <Label text="СРОК" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                    <VBox spacing="8">
                        <RadioButton fx:id="dueDateAny" selected="true" text="Любой"/>
                        <RadioButton fx:id="dueDateToday" text="Сегодня"/>
                        <RadioButton fx:id="dueDateWeek" text="Неделя"/>
                        <RadioButton fx:id="dueDateOverdue" text="Просроченные"/>
                    </VBox>
                </VBox>
                <VBox spacing="10">
                    <Label text="СТАТУС" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                    <VBox spacing="8">
                        <RadioButton fx:id="statusAll" selected="true" text="Все"/>
                        <RadioButton fx:id="statusActive" text="Активные"/>
                        <RadioButton fx:id="statusCompleted" text="Выполненные"/>
                    </VBox>
                </VBox>
                <VBox spacing="10">
                    <Label text="БЫСТРЫЕ" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                    <HBox spacing="10">
                        <Button fx:id="todayButton" onAction="#setQuickFilterToday"
                                style="-fx-pref-width: 120; -fx-background-color: #1565c0; -fx-text-fill: white; -fx-background-radius: 0;"
                                text="СЕГОДНЯ"/>
                        <Button fx:id="overdueButton" onAction="#setQuickFilterOverdue"
                                style="-fx-pref-width: 120; -fx-background-color: #1565c0; -fx-text-fill: white; -fx-background-radius: 0;"
                                text="ПРОСРОЧЕННЫЕ"/>
                        <Button fx:id="completedButton" onAction="#setQuickFilterCompleted"
                                style="-fx-pref-width: 120; -fx-background-color: #1565c0; -fx-text-fill: white; -fx-background-radius: 0;"
                                text="ВЫПОЛНЕННЫЕ"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 15; -fx-border-color: black; -fx-border-width: 1 0 0 0;">
            <Button fx:id="resetButton" onAction="#resetFilters"
                    style="-fx-background-color: #333; -fx-text-fill: white; -fx-background-radius: 0;"
                    text="СБРОС"/>
            <Button fx:id="applyButton" onAction="#applyFilters"
                    style="-fx-background-color: #1565c0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 0;"
                    text="ПРИМЕНИТЬ"/>
        </HBox>
    </bottom>
</BorderPane>