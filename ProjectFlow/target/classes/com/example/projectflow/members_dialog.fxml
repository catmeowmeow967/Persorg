<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>
<BorderPane prefWidth="800" prefHeight="600"
            style="-fx-background-color: white; -fx-border-color: black; -fx-border-width: 1;"
            xmlns="http://javafx.com/javafx/17.0.2"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.MembersController">
    <top>
        <VBox style="-fx-background-color: #1565c0; -fx-padding: 20;">
            <Label text="УЧАСТНИКИ"
                   style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Управление доступом"
                   style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12;"/>
        </VBox>
    </top>
    <center>
        <VBox spacing="20" style="-fx-padding: 20;">
            <VBox spacing="15" style="-fx-background-color: #f5f5f5; -fx-padding: 15; -fx-border-color: #999; -fx-border-width: 1;">
                <Label text="ПРИГЛАСИТЬ"
                       style="-fx-font-weight: bold; -fx-text-fill: black; -fx-font-size: 14;"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="inviteEmailField"
                               promptText="Email..."
                               style="-fx-pref-width: 300; -fx-pref-height: 32; -fx-border-color: #999; -fx-border-width: 1;"/>
                    <ComboBox fx:id="roleCombo" promptText="Роль"
                              style="-fx-pref-height: 32;">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Участник"/>
                                <String fx:value="Администратор"/>
                                <String fx:value="Наблюдатель"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                    <Button fx:id="inviteButton" text="ОТПРАВИТЬ"
                            onAction="#inviteMember"
                            style="-fx-background-color: #1565c0; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-height: 32; -fx-background-radius: 0;"/>
                </HBox>
            </VBox>
            <VBox spacing="10">
                <Label text="ПОИСК" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                <TextField fx:id="searchMemberField"
                           promptText="Имя, email или роль..."
                           style="-fx-font-size: 13; -fx-border-color: #999; -fx-border-width: 1;"/>
            </VBox>
            <VBox spacing="10">
                <Label text="СПИСОК" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                <TableView fx:id="membersTable" prefHeight="350"
                           style="-fx-border-color: #999; -fx-border-width: 1;"/>
            </VBox>
        </VBox>
    </center>
    <bottom>
        <VBox spacing="5" style="-fx-padding: 15; -fx-background-color: #f5f5f5; -fx-border-color: black; -fx-border-width: 1 0 0 0;">
            <Label fx:id="projectOwnerLabel" style="-fx-font-weight: bold;"/>
            <Label fx:id="totalMembersLabel" style="-fx-text-fill: #333;"/>
        </VBox>
    </bottom>
</BorderPane>